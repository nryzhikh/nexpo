{
  "name": "@nexpo/ui-tokens",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./cjs": {
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "style-dictionary": "*"
  }
}
